# Backend environment
# Copy the relevant values into backend/.env.

OPENAI_API_KEY=sk-proj-your-real-key-here
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BENCHMARK_MODELS=gpt-5.5
OPENAI_SEMAPHORE_SIZE=3

# Optional database settings.
# Leave as file:local_scores.db for local development.
TURSO_DATABASE_URL=file:local_scores.db
TURSO_AUTH_TOKEN=

# Frontend environment
# Optional. Set this only if the backend is not running on localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:8000
